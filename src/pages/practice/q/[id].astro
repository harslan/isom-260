---
import PracticeLayout from '../../../layouts/PracticeLayout.astro';
import Icon from '../../../components/Icon.astro';
import {
  questions,
  getQuestion,
  getDomain,
  getDomainQuestions,
} from '../../../data/questions';
import { renderMarkdown } from '../../../data/practice-md';

export function getStaticPaths() {
  return questions.map((q) => ({ params: { id: q.id } }));
}

const { id } = Astro.params;
const question = getQuestion(id as string);
if (!question) {
  return Astro.redirect('/practice');
}

const domain = getDomain(question.domain)!;
const domainQs = getDomainQuestions(question.domain);
const idxInDomain = domainQs.findIndex((q) => q.id === question.id);
const prevQ = idxInDomain > 0 ? domainQs[idxInDomain - 1] : null;
const nextQ = idxInDomain < domainQs.length - 1 ? domainQs[idxInDomain + 1] : null;

const scenarioHtml = renderMarkdown(question.scenario);
const correctExplanationHtml = renderMarkdown(question.correctExplanation);

const distractorEntries = (['A', 'B', 'C', 'D'] as const)
  .filter((k) => k !== question.correctAnswer && question.distractors[k])
  .map((k) => ({
    id: k,
    misconception: question.distractors[k]!.misconception,
    explanationHtml: renderMarkdown(question.distractors[k]!.explanation),
  }));

const optionLabels = question.options.map((o) => ({
  id: o.id,
  textHtml: renderMarkdown(o.text),
  isCorrect: o.id === question.correctAnswer,
}));

const tagsForData = question.tags.join(',');
---

<PracticeLayout
  title={`${question.id} | ${domain.shortTitle} | ISOM 260 Practice`}
  description={question.question}
>
  <article class="max-w-[820px] mx-auto px-8 pt-12 pb-32" data-question-id={question.id}>
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-text-muted text-sm mb-8">
      <a href="/practice" class="hover:text-accent-cyan transition-colors no-underline">Practice</a>
      <Icon name="chevron-right" class="w-3 h-3" />
      <a href={`/practice/${domain.id}`} class="hover:text-accent-cyan transition-colors no-underline">{domain.shortTitle}</a>
      <Icon name="chevron-right" class="w-3 h-3" />
      <span class="font-mono text-text-muted">{question.id}</span>
    </div>

    <!-- Domain badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 bg-bg-card border border-border-subtle rounded-full">
      <Icon name={domain.icon} class="w-3.5 h-3.5 text-accent-purple" />
      <span class="font-mono text-[0.7rem] text-text-secondary tracking-[2px] uppercase">
        Domain {domain.number} &middot; {domain.shortTitle}
      </span>
    </div>

    <!-- Scenario -->
    <section class="mb-10">
      <div class="font-mono text-[0.7rem] text-accent-cyan tracking-[3px] uppercase mb-3">
        Scenario
      </div>
      <div class="prose-practice" set:html={scenarioHtml}></div>
    </section>

    <!-- Question stem -->
    <section class="mb-10">
      <h1 class="text-[clamp(1.4rem,3vw,1.875rem)] font-semibold leading-snug">
        {question.question}
      </h1>
    </section>

    <!-- Options -->
    <section class="mb-10">
      <div
        class="font-mono text-[0.7rem] text-accent-cyan tracking-[3px] uppercase mb-4"
      >
        Choose your answer
      </div>
      <fieldset id="options-fieldset" class="space-y-3 border-0 p-0 m-0">
        {optionLabels.map((opt) => (
          <label
            class="option-row group block cursor-pointer bg-bg-card border border-border-subtle rounded-xl p-5 transition-all duration-200 hover:border-accent-cyan/30 has-[:checked]:border-accent-cyan has-[:checked]:bg-accent-cyan/5"
            data-option-id={opt.id}
            data-is-correct={opt.isCorrect ? 'true' : 'false'}
          >
            <div class="flex items-start gap-4">
              <span class="option-letter font-mono text-sm text-text-muted group-has-[:checked]:text-accent-cyan transition-colors w-6 shrink-0">
                {opt.id}
              </span>
              <input
                type="radio"
                name="answer"
                value={opt.id}
                class="sr-only"
              />
              <div class="prose-practice text-[0.95rem] flex-1" set:html={opt.textHtml}></div>
              <span class="result-icon w-5 h-5 shrink-0 self-center hidden">
                <Icon name="check" class="w-5 h-5 text-accent-green hidden result-correct" />
                <Icon name="x" class="w-5 h-5 text-accent-orange hidden result-wrong" />
              </span>
            </div>
          </label>
        ))}
      </fieldset>
    </section>

    <!-- Reasoning before revealing -->
    <section class="mb-10" id="reasoning-section">
      <div class="font-mono text-[0.7rem] text-accent-cyan tracking-[3px] uppercase mb-3">
        Before you reveal — write your reasoning
      </div>
      <p class="text-text-secondary text-sm mb-4 max-w-[640px]">
        Why did you pick that answer? Two or three sentences. The act of articulating it
        is what builds the judgment — not the click that follows.
      </p>
      <textarea
        id="reasoning-input"
        rows="5"
        placeholder="I picked B because…"
        class="w-full bg-bg-card border border-border-subtle rounded-xl p-4 text-text-primary placeholder:text-text-muted resize-y focus:outline-none focus:border-accent-cyan transition-colors text-[0.95rem] leading-relaxed font-sans"
      ></textarea>
      <div class="flex items-center justify-end mt-2 text-xs text-text-muted">
        <span class="italic">Saved locally to your device.</span>
      </div>
    </section>

    <!-- Reveal action -->
    <section class="mb-10">
      <button
        id="reveal-btn"
        type="button"
        disabled
        class="reveal-btn inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-accent-cyan to-accent-purple text-bg-primary rounded-full font-semibold transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed enabled:hover:-translate-y-0.5 enabled:hover:shadow-[0_10px_40px_rgba(0,212,255,0.3)] cursor-pointer border-0"
      >
        <Icon name="eye" class="w-4 h-4" />
        Reveal answer
      </button>
      <div id="reveal-hint" class="text-text-muted text-xs mt-3">
        Pick an option and write a sentence of reasoning to enable.
      </div>
    </section>

    <!-- Reveal panel (hidden until reveal) -->
    <section id="reveal-panel" class="hidden">
      <!-- Verdict -->
      <div id="verdict" class="rounded-2xl p-6 mb-8 border" data-correct="">
        <div class="flex items-start gap-4">
          <div id="verdict-icon" class="shrink-0 mt-0.5"></div>
          <div class="flex-1">
            <div id="verdict-title" class="text-lg font-semibold mb-2"></div>
            <div id="verdict-subtitle" class="text-text-secondary text-sm mb-4"></div>
            <button
              id="try-again-btn"
              type="button"
              class="inline-flex items-center gap-2 px-4 py-2 border border-border-subtle rounded-full text-text-secondary text-sm hover:border-accent-cyan hover:text-accent-cyan transition-all cursor-pointer bg-transparent"
            >
              <Icon name="copy" class="w-3.5 h-3.5" />
              Try again with fresh eyes
            </button>
          </div>
        </div>
      </div>

      <!-- Echo back the reasoning -->
      <div class="mb-8 p-5 border-l-2 border-accent-purple/40 bg-bg-card/50 rounded-r-lg">
        <div class="font-mono text-[0.7rem] text-accent-purple tracking-[3px] uppercase mb-2">
          Your reasoning
        </div>
        <div id="echoed-reasoning" class="prose-practice italic text-text-secondary"></div>
      </div>

      <!-- Why correct -->
      <section class="mb-10">
        <div class="font-mono text-[0.7rem] text-accent-green tracking-[3px] uppercase mb-3">
          Why <span class="text-accent-cyan font-bold">{question.correctAnswer}</span> is correct
        </div>
        <div class="prose-practice" set:html={correctExplanationHtml}></div>
      </section>

      <!-- Why each distractor is wrong -->
      <section class="mb-10">
        <div class="font-mono text-[0.7rem] text-accent-orange tracking-[3px] uppercase mb-4">
          Why the others are wrong &middot; named misconceptions
        </div>
        <div class="space-y-5">
          {distractorEntries.map((d) => (
            <div class="bg-bg-card border border-border-subtle rounded-xl p-5">
              <div class="flex items-baseline gap-3 mb-3">
                <span class="font-mono text-sm text-text-muted">{d.id}</span>
                <div class="flex-1">
                  <div class="font-mono text-[0.65rem] text-accent-orange tracking-[2px] uppercase mb-1">
                    Misconception
                  </div>
                  <div class="text-[1rem] font-semibold text-text-primary">
                    {d.misconception}
                  </div>
                </div>
              </div>
              <div class="prose-practice text-[0.95rem]" set:html={d.explanationHtml}></div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tags -->
      {question.tags.length > 0 && (
        <section class="mb-10">
          <div class="flex flex-wrap gap-2">
            {question.tags.map((tag) => (
              <span class="px-3 py-1 bg-accent-purple/10 rounded-full text-[0.7rem] text-accent-purple font-mono">
                {tag}
              </span>
            ))}
          </div>
        </section>
      )}
    </section>

    <!-- Navigation -->
    <nav class="flex items-center justify-between gap-4 pt-8 border-t border-border-subtle">
      {prevQ ? (
        <a
          href={`/practice/q/${prevQ.id}`}
          class="inline-flex items-center gap-2 text-text-secondary hover:text-accent-cyan transition-colors no-underline text-sm"
        >
          <Icon name="chevron-right" class="w-4 h-4 rotate-180" />
          Previous
          <span class="font-mono text-text-muted ml-1">{prevQ.id}</span>
        </a>
      ) : (
        <a
          href={`/practice/${domain.id}`}
          class="inline-flex items-center gap-2 text-text-muted hover:text-accent-cyan transition-colors no-underline text-sm"
        >
          <Icon name="chevron-right" class="w-4 h-4 rotate-180" />
          Back to {domain.shortTitle}
        </a>
      )}

      {nextQ ? (
        <a
          href={`/practice/q/${nextQ.id}`}
          class="next-btn inline-flex items-center gap-2 text-text-secondary hover:text-accent-cyan transition-colors no-underline text-sm"
        >
          Next
          <span class="font-mono text-text-muted ml-1">{nextQ.id}</span>
          <Icon name="chevron-right" class="w-4 h-4" />
        </a>
      ) : (
        <a
          href={`/practice/${domain.id}`}
          class="inline-flex items-center gap-2 text-text-muted hover:text-accent-cyan transition-colors no-underline text-sm"
        >
          Back to {domain.shortTitle}
          <Icon name="chevron-right" class="w-4 h-4" />
        </a>
      )}
    </nav>
  </article>

  <script
    is:inline
    define:vars={{
      questionId: question.id,
      correctAnswer: question.correctAnswer,
      tagsCsv: tagsForData,
      distractorMap: Object.fromEntries(
        distractorEntries.map((d) => [d.id, d.misconception])
      ),
    }}
  >
    document.addEventListener('DOMContentLoaded', () => {
      const fieldset = document.getElementById('options-fieldset');
      const reasoning = document.getElementById('reasoning-input');
      const revealBtn = document.getElementById('reveal-btn');
      const revealHint = document.getElementById('reveal-hint');
      const revealPanel = document.getElementById('reveal-panel');
      const verdict = document.getElementById('verdict');
      const verdictTitle = document.getElementById('verdict-title');
      const verdictSubtitle = document.getElementById('verdict-subtitle');
      const verdictIcon = document.getElementById('verdict-icon');
      const echoedReasoning = document.getElementById('echoed-reasoning');
      const tryAgainBtn = document.getElementById('try-again-btn');

      const MIN_WORDS = 6;
      let revealed = false;

      // Restore prior attempt if present
      const prior = window.PracticeStore.getQuestion(questionId);

      function selectedOption() {
        const checked = fieldset.querySelector('input[name="answer"]:checked');
        return checked ? checked.value : null;
      }

      function wordCount(s) {
        const trimmed = (s || '').trim();
        if (!trimmed) return 0;
        return trimmed.split(/\s+/).length;
      }

      function updateRevealEnabled() {
        if (revealed) return;
        const opt = selectedOption();
        const words = wordCount(reasoning.value);
        const ok = !!opt && words >= MIN_WORDS;
        revealBtn.disabled = !ok;
        if (revealHint) {
          if (!opt && words < MIN_WORDS) {
            revealHint.textContent = 'Pick an option and write a sentence of reasoning to enable.';
          } else if (!opt) {
            revealHint.textContent = 'Pick an option to enable.';
          } else if (words < MIN_WORDS) {
            revealHint.textContent = 'Write a sentence — even a short one — to enable.';
          } else {
            revealHint.textContent = 'Ready when you are.';
          }
        }
      }

      fieldset.addEventListener('change', updateRevealEnabled);
      reasoning.addEventListener('input', updateRevealEnabled);

      function reveal() {
        if (revealed) return;
        const opt = selectedOption();
        if (!opt) return;
        revealed = true;
        selected = opt;

        // Persist
        const misconception = opt !== correctAnswer ? distractorMap[opt] : null;
        window.PracticeStore.record(questionId, {
          selectedAnswer: opt,
          correctAnswer: correctAnswer,
          reasoning: reasoning.value || '',
          misconception: misconception,
        });

        // Lock options + reasoning
        fieldset.querySelectorAll('input[name="answer"]').forEach((el) => {
          el.disabled = true;
        });
        reasoning.disabled = true;
        revealBtn.disabled = true;
        revealBtn.textContent = 'Revealed';

        // Mark options visually
        fieldset.querySelectorAll('.option-row').forEach((row) => {
          const id = row.getAttribute('data-option-id');
          const isCorrect = row.getAttribute('data-is-correct') === 'true';
          const iconWrap = row.querySelector('.result-icon');
          if (iconWrap) iconWrap.classList.remove('hidden');
          if (isCorrect) {
            row.classList.add('!border-accent-green', 'bg-accent-green/5');
            const checkIcon = row.querySelector('.result-correct');
            if (checkIcon) checkIcon.classList.remove('hidden');
          } else if (id === opt) {
            row.classList.add('!border-accent-orange', 'bg-accent-orange/5');
            const xIcon = row.querySelector('.result-wrong');
            if (xIcon) xIcon.classList.remove('hidden');
          } else {
            row.classList.add('opacity-50');
          }
        });

        // Verdict
        const isCorrect = opt === correctAnswer;
        if (isCorrect) {
          verdict.classList.add('border-accent-green/40', 'bg-accent-green/5');
          verdictTitle.textContent = 'Correct.';
          verdictSubtitle.innerHTML =
            'You picked <span class="font-mono text-accent-green">' + opt + '</span>. Read the explanation below — the reasoning matters more than the result.';
          verdictIcon.innerHTML =
            '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-green"><path d="M20 6 9 17l-5-5"/></svg>';
        } else {
          verdict.classList.add('border-accent-orange/40', 'bg-accent-orange/5');
          verdictTitle.textContent = 'Not quite.';
          verdictSubtitle.innerHTML =
            'You picked <span class="font-mono text-accent-orange">' + opt +
            '</span>. The correct answer is <span class="font-mono text-accent-green">' +
            correctAnswer + '</span>. The misconception you fell for has a name — see below.';
          verdictIcon.innerHTML =
            '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-orange"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/></svg>';
        }

        // Echo reasoning
        const r = (reasoning.value || '').trim();
        if (echoedReasoning) {
          echoedReasoning.textContent = r ? '"' + r + '"' : '(no reasoning recorded)';
        }

        // Show panel + collapse the reasoning prompt
        revealPanel.classList.remove('hidden');
        revealPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      revealBtn.addEventListener('click', reveal);

      function resetView() {
        revealed = false;
        // Re-enable inputs
        fieldset.querySelectorAll('input[name="answer"]').forEach((el) => {
          el.disabled = false;
          el.checked = false;
        });
        reasoning.disabled = false;
        reasoning.value = '';
        // Reset option visuals
        fieldset.querySelectorAll('.option-row').forEach((row) => {
          row.classList.remove(
            '!border-accent-green', 'bg-accent-green/5',
            '!border-accent-orange', 'bg-accent-orange/5',
            'opacity-50'
          );
          const iconWrap = row.querySelector('.result-icon');
          if (iconWrap) iconWrap.classList.add('hidden');
          row.querySelectorAll('.result-correct, .result-wrong').forEach((el) => el.classList.add('hidden'));
        });
        // Reset verdict + reveal panel
        verdict.classList.remove(
          'border-accent-green/40', 'bg-accent-green/5',
          'border-accent-orange/40', 'bg-accent-orange/5'
        );
        verdictTitle.textContent = '';
        verdictSubtitle.innerHTML = '';
        verdictIcon.innerHTML = '';
        revealPanel.classList.add('hidden');
        // Reset reveal button
        revealBtn.disabled = true;
        revealBtn.innerHTML =
          '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg> Reveal answer';
        updateRevealEnabled();
        reasoning.focus();
      }

      tryAgainBtn.addEventListener('click', () => {
        // Drop the prior record (and decrement its misconception count)
        window.PracticeStore.clearQuestion(questionId);
        resetView();
        // Scroll back to the question stem
        document.querySelector('h1')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      // Restore prior attempt: pre-select option and reasoning, auto-reveal so the
      // returning student sees their previous result without losing the option to retry.
      if (prior && prior.attempted) {
        const radio = fieldset.querySelector('input[name="answer"][value="' + prior.selectedAnswer + '"]');
        if (radio) radio.checked = true;
        if (prior.reasoning) reasoning.value = prior.reasoning;
        reveal();
      } else {
        updateRevealEnabled();
      }
    });
  </script>
</PracticeLayout>
