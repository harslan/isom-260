---
import {
  ArrowRight,
  Award,
  Bot,
  Box,
  Brain,
  Calendar,
  Camera,
  Check,
  ChevronRight,
  ChevronsDown,
  Clock,
  Code,
  Copy,
  Database,
  Download,
  Eye,
  FileText,
  Github,
  Inbox,
  Layout,
  Mail,
  Menu,
  MessageCircle,
  MessageSquare,
  Network,
  Play,
  PlayCircle,
  Presentation,
  Rocket,
  Search,
  Shield,
  ShieldAlert,
  Sparkles,
  Target,
  Terminal,
  TrendingUp,
  Type,
  User,
  Users,
  Wrench,
  X,
  Zap,
} from '@lucide/astro';

interface Props {
  name: string;
  class?: string;
  size?: number;
}

const iconMap: Record<string, any> = {
  'arrow-right': ArrowRight,
  'award': Award,
  'bot': Bot,
  'box': Box,
  'brain': Brain,
  'calendar': Calendar,
  'camera': Camera,
  'check': Check,
  'chevron-right': ChevronRight,
  'chevrons-down': ChevronsDown,
  'clock': Clock,
  'code': Code,
  'copy': Copy,
  'database': Database,
  'download': Download,
  'eye': Eye,
  'file-text': FileText,
  'github': Github,
  'inbox': Inbox,
  'layout': Layout,
  'mail': Mail,
  'menu': Menu,
  'message-circle': MessageCircle,
  'message-square': MessageSquare,
  'network': Network,
  'play': Play,
  'play-circle': PlayCircle,
  'presentation': Presentation,
  'rocket': Rocket,
  'search': Search,
  'shield': Shield,
  'shield-alert': ShieldAlert,
  'sparkles': Sparkles,
  'target': Target,
  'terminal': Terminal,
  'trending-up': TrendingUp,
  'type': Type,
  'user': User,
  'users': Users,
  'wrench': Wrench,
  'x': X,
  'zap': Zap,
};

const { name, class: className, size } = Astro.props;
const IconComponent = iconMap[name];
---

{IconComponent ? (
  <IconComponent class={className} size={size} />
) : (
  <span class={className} title={`Unknown icon: ${name}`}>?</span>
)}
