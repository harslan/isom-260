---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="flex gap-4 items-start">
  <div class="shrink-0 w-8 h-8 bg-gradient-to-br from-accent-cyan to-accent-purple rounded-full flex items-center justify-center font-bold text-[0.85rem] text-white">{number}</div>
  <div>
    <h4 class="text-base font-semibold mb-1">{title}</h4>
    <p class="text-text-secondary text-[0.9rem]">{description}</p>
  </div>
</div>
