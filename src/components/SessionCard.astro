---
import Icon from './Icon.astro';

interface Props {
  number: number;
  slug: string;
  title: string;
  subtitle: string;
  icon: string;
  tags?: string[];
}

const { number, slug, title, subtitle, icon, tags = [] } = Astro.props;
const numStr = String(number).padStart(2, '0');
---

<a href={`/sessions/${slug}`} class="group block bg-bg-card border border-border-subtle rounded-2xl p-8 transition-all duration-300 no-underline text-inherit hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-[0_0_60px_rgba(0,212,255,0.15)]">
  <div class="flex items-center gap-4 mb-4">
    <div class="font-mono text-3xl font-bold bg-gradient-to-br from-accent-cyan to-accent-purple bg-clip-text text-transparent">{numStr}</div>
    <Icon name={icon} class="w-6 h-6 text-accent-purple" />
  </div>
  <h3 class="text-lg font-semibold mb-2 transition-colors duration-300 group-hover:text-accent-cyan">{title}</h3>
  <p class="text-text-secondary text-sm mb-4">{subtitle}</p>
  {tags.length > 0 && (
    <div class="flex gap-2 flex-wrap">
      {tags.map((tag) => (
        <span class="px-3 py-1 bg-accent-purple/10 rounded-full text-[0.7rem] text-accent-purple">{tag}</span>
      ))}
    </div>
  )}
</a>
